# Copy to .env and adjust. Never commit .env.

# Required for production (DEBUG=False). For local dev you may omit and a dev fallback is used only when DEBUG=True.
SECRET_KEY=change-me-to-a-long-random-string

# true/false — use false in production
DEBUG=true

# Comma-separated hostnames (no spaces), e.g. localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: Cloudinary (all three required to enable SDK config; set USE_CLOUDINARY_STORAGE for default file storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Set to true only when you want Django to store uploads in Cloudinary by default
USE_CLOUDINARY_STORAGE=false
